  "query": "\n            SELECT\n                p.Partie_ID as \"id: i32\",\n                p.Partiedatum as \"date\",\n                p.Spielkopie_ID as \"copy_id: i32\",\n                GROUP_CONCAT(t.Spieler_Email) as \"participants: String\"\n            FROM Partie p\n            LEFT JOIN Teilnahme t ON p.Partie_ID = t.Partie_ID\n            GROUP BY p.Partie_ID\n            ",
